# Copy to `.env` in the project root. The API loads `.env` only (not this example file).
GEMINI_API_KEY=your_gemini_api_key_here
CATALOG_PATH=app/data/catalog.json
FAISS_INDEX_PATH=app/data/faiss.index
CATALOG_META_PATH=app/data/catalog_meta.json
EMBEDDINGS_PATH=app/data/embeddings.npy
MAX_CONVERSATION_TURNS=8
# New API keys: use gemini-2.5-flash (or gemini-1.5-flash if your project is restricted).
GEMINI_MODEL=gemini-2.5-flash
REQUEST_TIMEOUT_SECONDS=25
